<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scroller Setup"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Follow the steps below to enable autonomous control."
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 1 — Accessibility Service"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/service_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility service: UNKNOWN"
            android:textSize="16sp" />

        <Button
            android:id="@+id/open_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Open Accessibility Settings" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 2 — Screen Capture Permission"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/projection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Screen capture: UNKNOWN"
            android:textSize="16sp" />

        <Button
            android:id="@+id/request_projection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Request Screen Capture Permission" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 3 — LLM Provider"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/llm_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gemini API key: NOT CONFIGURED"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/api_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Paste Gemini API key (not persisted)"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/apply_api_key"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Apply API Key" />

        <EditText
            android:id="@+id/model_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Gemini model (e.g., gemini-1.5-flash)"
            android:text="gemini-1.5-flash" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Step 4 — Run Loop"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/goal_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Enter goal (e.g., Open Settings and enable Wi‑Fi)" />

        <Button
            android:id="@+id/run_loop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Run Loop" />

        <TextView
            android:id="@+id/loop_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loop status: IDLE" />

        <TextView
            android:id="@+id/next_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Next step: Enable Accessibility service"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="LLM keys are held in memory only for this session." />

    </LinearLayout>
</ScrollView>
